# ==============================================================================
# Terraform Runtime & Cache Files
# ==============================================================================
# Local directory created by 'terraform init' containing downloaded provider plugins
.terraform/

# Hide execution plans generated by 'terraform plan -out=tfplan'
*.tfplan
*.tfplan.binary

# ==============================================================================
# Terraform State Locks & Local State (Crucial)
# ==============================================================================
# Since we implemented Centralized Remote State, local state files should NEVER be committed
*.tfstate
*.tfstate.[0-9]*
*.tfstate.lock.info

# Ignore crash logs in case a provider plugin panics
crash.log
crash.*.log

# ==============================================================================
# Secrets & Variables (Crucial Security Rails)
# ==============================================================================
# Protects your sensitive inputs (like 'db-password' inside terraform.tfvars)
*.tfvars
*.tfvars.json
!*.sample.tfvars

# Prevent override configuration layers from leaking
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# ==============================================================================
# System & IDE Specific Files
# ==============================================================================
# MacOS files
.DS_Store

# Windows files
Thumbs.db

# VS Code / IntelliJ / Cursor directories
.vscode/
.idea/
*.iml
.terraform.lock.hcl